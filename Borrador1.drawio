        </mxCell>
        <mxCell id="XD4TbhY-R0S7dqyoedOY-58" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="Para calcular el costo de un insumo de producción debes considerar no solo el precio de compra, sino también los costos asociados como transporte, almacenamiento, desperdicio, mano de obra vinculada y gastos indirectos. Esto asegura que el costo real refleje el impacto total en la rentabilidad del producto." vertex="1">
          <mxGeometry height="30" width="250" x="830" y="450" as="geometry" />
        </mxCell>
        <mxCell id="XD4TbhY-R0S7dqyoedOY-59" edge="1" parent="1" style="endArrow=classic;html=1;rounded=0;" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="640" y="470" as="sourcePoint" />
            <mxPoint x="760" y="270" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="XD4TbhY-R0S7dqyoedOY-60" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;h2&gt;Factores Clave&lt;/h2&gt;&lt;h3&gt;1. &lt;strong&gt;Costos Directos&lt;/strong&gt;&lt;/h3&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;Salario base&lt;/strong&gt;: pago por hora, día o unidad producida.&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;Prestaciones sociales&lt;/strong&gt;: seguridad social, salud, pensión, cesantías, vacaciones, primas.&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;Horas extras y recargos&lt;/strong&gt;: nocturnos, dominicales o festivos.&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;Bonificaciones o incentivos&lt;/strong&gt;: pagos adicionales ligados a productividad o calidad.&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h3&gt;2. &lt;strong&gt;Costos Indirectos&lt;/strong&gt;&lt;/h3&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;Capacitación&lt;/strong&gt;: cursos, entrenamientos, inducciones.&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;Uniformes y equipos de protección&lt;/strong&gt;: dotación obligatoria.&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;Herramientas y equipos de trabajo&lt;/strong&gt;: mantenimiento y depreciación.&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;Supervisión y control de calidad&lt;/strong&gt;: tiempo de jefes o coordinadores.&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="350" width="560" x="760" y="30" as="geometry" />
        </mxCell>
      </root>
