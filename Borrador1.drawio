        <mxCell id="XD4TbhY-R0S7dqyoedOY-57" edge="1" parent="1" style="endArrow=classic;html=1;rounded=0;" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="640" y="500" as="sourcePoint" />
